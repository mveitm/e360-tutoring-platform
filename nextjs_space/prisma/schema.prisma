generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/tutoring_platform_mvp/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Student {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String   @unique
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  programInstances StudentProgramInstance[]

  @@map("students")
}

model Program {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  vertical  String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programInstances StudentProgramInstance[]
  axes             Axis[]
  skills           Skill[]

  @@map("programs")
}

model StudentProgramInstance {
  id                    String    @id @default(cuid())
  studentId             String
  programId             String
  status                String    @default("active")
  startedAt             DateTime  @default(now())
  endedAt               DateTime?
  lastActivityAt        DateTime?
  currentCycleId        String?
  currentContinuityState String   @default("normal")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  student        Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program        Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  skillStates        SkillState[]
  learningCycles     LearningCycle[]
  diagnostics        Diagnostic[]
  continuitySignals  ContinuitySignal[]

  @@map("student_program_instances")
}

model Axis {
  id           String   @id @default(cuid())
  programId    String
  code         String
  name         String
  displayOrder Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  skills  Skill[]

  @@unique([programId, code])
  @@map("axes")
}

model Skill {
  id           String   @id @default(cuid())
  programId    String
  axisId       String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  program             Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  axis                Axis                 @relation(fields: [axisId], references: [id], onDelete: Cascade)
  skillStates         SkillState[]
  cycleDecisionSkills CycleDecisionSkill[]
  responses           Response[]

  @@unique([programId, code])
  @@map("skills")
}

model SkillState {
  id                 String    @id @default(cuid())
  enrollmentId       String
  skillId            String
  masteryLevel       String    @default("not_evaluated")
  confidenceLevel    String    @default("none")
  needsReinforcement Boolean   @default(false)
  lastEvaluatedAt    DateTime?
  stateSource        String    @default("manual")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  enrollment StudentProgramInstance @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  skill      Skill                  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, skillId])
  @@map("skill_states")
}

model LearningCycle {
  id           String    @id @default(cuid())
  enrollmentId String
  cycleNumber  Int
  status       String    @default("open")
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollment       StudentProgramInstance @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  cycleDecisions   CycleDecision[]
  studyLoads       StudyLoad[]
  cycleEvaluations CycleEvaluation[]
  cycleSnapshots    CycleSnapshot[]
  tutoringSessions  TutoringSession[]
  continuitySignals ContinuitySignal[]

  @@unique([enrollmentId, cycleNumber])
  @@map("learning_cycles")
}

model CycleDecision {
  id              String   @id @default(cuid())
  learningCycleId String
  decisionType    String
  rationale       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learningCycle       LearningCycle        @relation(fields: [learningCycleId], references: [id], onDelete: Cascade)
  cycleDecisionSkills CycleDecisionSkill[]

  @@map("cycle_decisions")
}

model StudyLoad {
  id              String    @id @default(cuid())
  learningCycleId String
  loadType        String
  title           String
  status          String    @default("pending")
  releasedAt      DateTime?
  dueAt           DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  learningCycle    LearningCycle    @relation(fields: [learningCycleId], references: [id], onDelete: Cascade)
  tutoringSessions TutoringSession[]

  @@map("study_loads")
}

model CycleEvaluation {
  id              String   @id @default(cuid())
  learningCycleId String
  evaluationType  String
  resultSummary   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learningCycle     LearningCycle    @relation(fields: [learningCycleId], references: [id], onDelete: Cascade)
  continuitySignals ContinuitySignal[]

  @@map("cycle_evaluations")
}

model Diagnostic {
  id              String    @id @default(cuid())
  enrollmentId    String
  diagnosticType  String    @default("initial")
  status          String    @default("pending")
  resultSummary   String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  enrollment StudentProgramInstance @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("diagnostics")
}

model CycleSnapshot {
  id              String   @id @default(cuid())
  learningCycleId String
  snapshotType    String   @default("pre_decision")
  payload         Json?
  takenAt         DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learningCycle LearningCycle @relation(fields: [learningCycleId], references: [id], onDelete: Cascade)

  @@map("cycle_snapshots")
}

model CycleDecisionSkill {
  id              String   @id @default(cuid())
  cycleDecisionId String
  skillId         String
  priority        Int      @default(0)
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cycleDecision CycleDecision @relation(fields: [cycleDecisionId], references: [id], onDelete: Cascade)
  skill         Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([cycleDecisionId, skillId])
  @@map("cycle_decision_skills")
}

model TutoringSession {
  id              String    @id @default(cuid())
  learningCycleId String
  studyLoadId     String?
  sessionType     String    @default("practice")
  status          String    @default("in_progress")
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  learningCycle LearningCycle @relation(fields: [learningCycleId], references: [id], onDelete: Cascade)
  studyLoad     StudyLoad?    @relation(fields: [studyLoadId], references: [id], onDelete: SetNull)
  responses     Response[]

  @@map("sessions_pedagogical")
}

model Response {
  id                String   @id @default(cuid())
  tutoringSessionId String
  skillId           String?
  responseType      String   @default("answer")
  content           String?
  isCorrect         Boolean?
  score             Float?
  feedback          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tutoringSession TutoringSession @relation(fields: [tutoringSessionId], references: [id], onDelete: Cascade)
  skill           Skill?          @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@map("responses")
}

model ContinuitySignal {
  id             String   @id @default(cuid())
  enrollmentId   String
  learningCycleId String?
  evaluationId   String?
  signalType     String
  rationale      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollment    StudentProgramInstance @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  learningCycle LearningCycle?         @relation(fields: [learningCycleId], references: [id], onDelete: SetNull)
  evaluation    CycleEvaluation?       @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@map("continuity_signals")
}

// Phase FD — Append-only audit event log for mutation traceability.
// No FK to User (actorId stores "system" and future agent identities).
// No updatedAt (append-only by design — records must never be updated or deleted).
// No Prisma enums (consistent with project-wide String + application-validation pattern).
// HITL fields, correlationId, rationale, riskLevel, authorityTier, metadata deferred to later phases.
model AuditEvent {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  actorType     String   // human_admin | student | system | future_agent | external_tool
  actorId       String   // User.id, "system", or agent identity
  actorEmail    String?  // denormalized for query convenience

  actionType    String   // create | update | delete | status_transition
  domain        String   // learning_cycle | study_load | skill_state | ...
  entityType    String   // Prisma model name
  entityId      String   // PK of affected record

  endpoint      String   // API route path
  method        String   // HTTP method

  operationId   String?  // links multi-step workflow mutations

  beforePayload Json?    // state before mutation
  afterPayload  Json?    // state after mutation

  @@index([entityType, entityId])
  @@index([actorType, actorId])
  @@index([operationId])
  @@index([createdAt])
  @@map("audit_events")
}
